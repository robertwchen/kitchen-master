.pytest_cache/
.coverage
htmlcov/

# IDE / editor
.vscode/
.idea/
*.swp

# OS files
.DS_Store
Thumbs.db

# Results artifacts
results/logs/*
results/plots/*
results/tables/*

# Keep directories present
!results/logs/.gitkeep
!results/plots/.gitkeep
!results/tables/.gitkeep
